{
  "database": {
    "adapter": "redshift",
    "connection": {
      "comment": "Connection parameters loaded from shell environment variables"
    }
  },
  "active_schemas": [
    "scratch"
  ],
  "refresh": {
    "check_on_launch": true,
    "auto_refresh_threshold_days": 7,
    "include_row_counts": false
  },
  "extraction": {
    "max_schemas": 200,
    "exclude_patterns": [
      "pg_temp*",
      "pg_toast*"
    ],
    "categories": {
      "staging": "*_staging",
      "history": "*_history",
      "scratch": "*scratch*",
      "partner": "hulu,philo,plutotv,xumo,vix,xite,zype,amagi*"
    }
  },
  "ui": {
    "show_all_schemas": true,
    "default_limit": 100
  }
}

