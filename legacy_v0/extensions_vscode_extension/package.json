{
  "name": "datashark",
  "displayName": "DataShark",
  "description": "AI-native database IDE for Cursor",
  "version": "0.1.0",
  "publisher": "datashark",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:sql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "datashark.toggleDatabaseMode",
        "title": "DataShark: Toggle Database Mode"
      },
      {
        "command": "datashark.refreshMetadata",
        "title": "DataShark: Refresh Metadata",
        "icon": "$(refresh)"
      },
      {
        "command": "datashark.refreshSchemas",
        "title": "DataShark: Refresh Schemas",
        "icon": "$(refresh)"
      },
      {
        "command": "datashark.connectDatabase",
        "title": "DataShark: Connect to Database"
      },
      {
        "command": "datashark.executeQuery",
        "title": "DataShark: Execute Query"
      },
      {
        "command": "datashark.previewTableData",
        "title": "Preview Data (10 rows)"
      },
      {
        "command": "datashark.generateSelectQuery",
        "title": "Generate SELECT Query"
      },
      {
        "command": "datashark.copyTableName",
        "title": "Copy Table Name"
      },
      {
        "command": "datashark.findSimilarColumns",
        "title": "Find Similar Columns"
      },
      {
        "command": "datashark.showTableInfo",
        "title": "Show Table Info"
      },
      {
        "command": "datashark.formatQuery",
        "title": "DataShark: Format SQL Query"
      },
      {
        "command": "datashark.exportResults",
        "title": "DataShark: Export Query Results"
      },
      {
        "command": "datashark.newInstance",
        "title": "DataShark: New Instance",
        "icon": "$(add)"
      },
      {
        "command": "datashark.switchInstance",
        "title": "DataShark: Switch Instance",
        "icon": "$(replace)"
      },
      {
        "command": "datashark.buildInstance",
        "title": "DataShark: Build Instance",
        "icon": "$(gear)"
      },
      {
        "command": "datashark.generateSQL",
        "title": "DataShark: Generate SQL"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "datashark-explorer",
          "title": "DataShark",
          "icon": "resources/database-icon.svg"
        }
      ]
    },
    "views": {
      "datashark-explorer": [
        {
          "id": "datashark.schemaTree",
          "name": "Database Schema",
          "icon": "resources/database-icon.svg",
          "contextualTitle": "DataShark Schema"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "datashark.refreshMetadata",
          "when": "view == datashark.schemaTree",
          "group": "navigation"
        },
        {
          "command": "datashark.refreshSchemas",
          "when": "view == datashark.schemaTree",
          "group": "navigation"
        },
        {
          "command": "datashark.newInstance",
          "when": "view == datashark.schemaTree",
          "group": "navigation"
        },
        {
          "command": "datashark.switchInstance",
          "when": "view == datashark.schemaTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "datashark.previewTableData",
          "when": "view == datashark.schemaTree && viewItem == table",
          "group": "1_query@1"
        },
        {
          "command": "datashark.generateSelectQuery",
          "when": "view == datashark.schemaTree && viewItem == table",
          "group": "1_query@2"
        },
        {
          "command": "datashark.showTableInfo",
          "when": "view == datashark.schemaTree && viewItem == table",
          "group": "2_info@1"
        },
        {
          "command": "datashark.copyTableName",
          "when": "view == datashark.schemaTree && viewItem == table",
          "group": "3_copy@1"
        },
        {
          "command": "datashark.findSimilarColumns",
          "when": "view == datashark.schemaTree && viewItem == column",
          "group": "1_search@1"
        }
      ]
    },
    "configuration": {
      "title": "DataShark",
      "properties": {
        "datashark.mcpServerPath": {
          "type": "string",
          "default": "",
          "description": "Path to DataShark MCP server"
        },
        "datashark.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh metadata on startup"
        },
        "datashark.profile": {
          "type": "string",
          "default": "",
          "description": "DataShark profile name (for metadata context)"
        },
        "datashark.defaultDialect": {
          "type": "string",
          "default": "postgres",
          "enum": ["postgres", "duckdb", "bigquery"],
          "description": "Default SQL dialect for generated queries"
        }
      }
    },
    "keybindings": [
      {
        "command": "datashark.executeQuery",
        "key": "cmd+enter",
        "mac": "cmd+enter",
        "win": "ctrl+enter",
        "linux": "ctrl+enter",
        "when": "editorTextFocus && editorLangId == sql"
      },
      {
        "command": "datashark.formatQuery",
        "key": "shift+alt+f",
        "mac": "shift+alt+f",
        "win": "shift+alt+f",
        "linux": "shift+alt+f",
        "when": "editorTextFocus && editorLangId == sql"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "install-extension": "code --install-extension ."
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.130",
    "@types/vscode": "1.80",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3"
  }
}
