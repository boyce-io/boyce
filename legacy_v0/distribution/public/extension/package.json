{
  "name": "datashark-core",
  "displayName": "DataShark",
  "description": "Headless Semantic Kernel for deterministic SQL generation",
  "version": "0.1.0",
  "publisher": "datashark",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "datashark.generateSQL",
        "title": "DataShark: Generate SQL"
      }
    ],
    "configuration": {
      "datashark.mcpServerPath": {
        "type": "string",
        "default": "",
        "description": "Path to DataShark MCP server (auto-detected if bundled)"
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
