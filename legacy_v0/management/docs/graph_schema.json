{
    "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EnterpriseGraph",
  "definitions": {
    "provenance": {
      "type": "object",
      "required": ["system", "source_path", "extractor_version", "extracted_at"],
      "properties": {
        "system": {"type": "string"},
        "source_path": {"type": "string"},
        "extractor_version": {"type": "string"},
        "source_commit": {"type": ["string", "null"]},
        "extracted_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": true
    }
  },
  "oneOf": [
    {
      "title": "Node",
      "type": "object",
      "required": ["id", "system", "type", "name", "attributes", "provenance"],
      "properties": {
        "id": {"type": "string"},
        "system": {"type": "string"},
        "type": {"type": "string"},
        "name": {"type": "string"},
        "repo": {"type": ["string", "null"]},
        "schema": {"type": ["string", "null"]},
        "attributes": {"type": "object"},
        "provenance": {"$ref": "#/definitions/provenance"},
        "deleted_at": {"type": ["string", "null"], "format": "date-time"}
      },
      "additionalProperties": false
  },
    {
      "title": "Edge",
      "type": "object",
      "required": ["id", "src", "dst", "type", "attributes", "provenance"],
      "properties": {
        "id": {"type": "string"},
        "src": {"type": "string"},
        "dst": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["JOINS_TO", "DERIVES_FROM", "DEPENDS_ON", "DESCRIBES"]
        },
        "attributes": {"type": "object"},
        "provenance": {"$ref": "#/definitions/provenance"},
        "deleted_at": {"type": ["string", "null"], "format": "date-time"}
      },
      "additionalProperties": false
      }
  ]
}